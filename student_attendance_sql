-- Created database/table

CREATE DATABASE students_attendance;

CREATE TABLE student_attendance (
    student_id INT,
    student_name VARCHAR(100),
    grade_level INT,
    class_name VARCHAR(100),
    class_date DATE,
    attendance_status VARCHAR(20),
    learning_mode VARCHAR(20)
);

