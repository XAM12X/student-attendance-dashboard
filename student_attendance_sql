-- Analysis Queries 

--Selecting All attendance records
select *
from student_attendance;

--Total Number of Students Attendance
SELECT COUNT(DISTINCT student_id) AS total_students
FROM student_attendance;

--Total Attendance Status Breakdown for Each Learning Mode
SELECT attendance_status, COUNT(*) AS total_count
FROM student_attendance
GROUP BY attendance_status;

--Learning Mode Breakdown
SELECT learning_mode, COUNT(*) AS total_count
FROM student_attendance
group by learning_mode;

--Attedance By grade Level
SELECT grade_level, attendance_status,COUNT(*) AS total_gradelevel
FROM student_attendance
GROUP BY grade_level, attendance_status;

--Attendance trend overtime
SELECT class_date, attendance_status, COUNT(*) AS total_count
FROM student_attendance
GROUP BY class_date, attendance_status
ORDER BY class_date;


--Total percentage of Attendance Status of 'Abesen' and 'Present' 

--** Percentage Of Total of present attendance
SELECT
COUNT(CASE WHEN attendance_status = 'Present' THEN 1 END) * 100.0/COUNT(*) AS attendance_percentage
     FROM student_attendance;

--** Percentage of Total absent attendance  for students
SELECT
COUNT(CASE WHEN attendance_status = 'Absent' THEN 1 END) * 100.0/COUNT(*) AS absent_percentage
FROM student_attendance;


